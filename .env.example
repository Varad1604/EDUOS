# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://eduos:eduos_dev_pass@localhost:5432/eduos_dev
DATABASE_MAX_CONNECTIONS=20
DATABASE_MIN_CONNECTIONS=2

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── JWT ───────────────────────────────────────────────────────────────────────
JWT_SECRET=super_secret_jwt_key_change_in_production_min_32_chars
JWT_ACCESS_EXPIRY_MINUTES=15
JWT_REFRESH_EXPIRY_DAYS=7

# ── Server ────────────────────────────────────────────────────────────────────
SERVER_HOST=127.0.0.1
SERVER_PORT=8000
SERVER_REQUEST_TIMEOUT_SECS=30
SERVER_MAX_BODY_SIZE_MB=50

# ── CORS ──────────────────────────────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# ── Observability ─────────────────────────────────────────────────────────────
LOG_LEVEL=debug
# RUST_LOG=info,eduos_backend=debug,sqlx=warn
RUN_ENV=development
